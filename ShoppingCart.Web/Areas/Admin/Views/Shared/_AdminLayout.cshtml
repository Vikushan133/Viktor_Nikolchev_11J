<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="d-flex">
        <!-- Sidebar -->
        <div class="bg-dark text-white" style="width: 250px; min-height: 100vh;">
            <div class="p-3">
                <h5 class="text-center"><i class="bi bi-shop"></i> Fashion Store</h5>
                <hr class="border-secondary">
                <p class="text-muted small text-center">Admin Panel</p>
            </div>
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                        <i class="bi bi-speedometer2"></i> Табло
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="Admin" asp-controller="Products" asp-action="Index">
                        <i class="bi bi-box"></i> Продукти
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="Admin" asp-controller="Categories" asp-action="Index">
                        <i class="bi bi-tags"></i> Категории
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="Admin" asp-controller="Orders" asp-action="Index">
                        <i class="bi bi-truck"></i> Поръчки
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="Admin" asp-controller="Users" asp-action="Index">
                        <i class="bi bi-people"></i> Потребители
                    </a>
                </li>
            </ul>
            <hr class="border-secondary">
            <div class="p-3">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-outline-light btn-sm w-100">
                    <i class="bi bi-arrow-left"></i> Към магазина
                </a>
            </div>
        </div>

        <!-- Main Content -->
        <div class="flex-grow-1">
            <nav class="navbar navbar-light bg-light px-4 border-bottom">
                <span class="navbar-brand mb-0 h1">@ViewData["Title"]</span>
                <form asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="d-flex">
                    <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-outline-dark btn-sm">
                        <i class="bi bi-house"></i> Начало
                    </a>
                </form>
            </nav>
            <div class="p-4">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
