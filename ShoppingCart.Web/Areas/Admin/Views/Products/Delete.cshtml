@model Product
@{
    ViewData["Title"] = "Изтриване на " + Model.Name;
}

<h4>Сигурни ли сте, че искате да изтриете този продукт?</h4>
<div class="card border-0 shadow-sm">
    <div class="card-body">
        <h5>@Model.Name</h5>
        <p>@Model.Brand | @Model.Price.ToString("F2") лв.</p>
        <img src="@Model.ImageUrl" style="height: 200px; object-fit: cover;" alt="">
    </div>
</div>
<form asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="ProductId" />
    <button type="submit" class="btn btn-danger">Изтрий</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Отказ</a>
</form>
