@model AppUser
@{
    ViewData["Title"] = "Редактиране на " + Model.Email;
    var allRoles = ViewBag.AllRoles as List<string>;
    var userRoles = ViewBag.UserRoles as IList<string>;
}

<h4>Роли за @Model.Email</h4>

<form asp-action="Edit" method="post">
    <input type="hidden" name="id" value="@Model.Id" />
    <div class="mb-3">
        @foreach (var role in allRoles)
        {
            <div class="form-check">
                <input type="checkbox" name="roles" value="@role" class="form-check-input"
                       id="role_@role" @(userRoles.Contains(role) ? "checked" : "") />
                <label class="form-check-label" for="role_@role">@role</label>
            </div>
        }
    </div>
    <button type="submit" class="btn btn-dark">Запази</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Отказ</a>
</form>
