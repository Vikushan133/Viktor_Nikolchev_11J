@model IEnumerable<AppUser>
@{
    ViewData["Title"] = "Потребители";
}

<h4>Потребители</h4>

<table class="table table-hover">
    <thead>
        <tr>
            <th>Имейл</th>
            <th>Име</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Email</td>
                <td>@user.FullName</td>
                <td><a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i> Роли</a></td>
            </tr>
        }
    </tbody>
</table>
