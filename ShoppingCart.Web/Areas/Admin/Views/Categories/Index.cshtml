@model IEnumerable<Category>
@{
    ViewData["Title"] = "Категории";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Категории</h4>
    <a asp-action="Create" class="btn btn-dark"><i class="bi bi-plus"></i> Нова категория</a>
</div>

<table class="table table-hover">
    <thead>
        <tr>
            <th>ID</th>
            <th>Име</th>
            <th>Описание</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var cat in Model)
        {
            <tr>
                <td>@cat.CategoryId</td>
                <td>@cat.Name</td>
                <td>@cat.Description</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@cat.CategoryId" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                    <a asp-action="Delete" asp-route-id="@cat.CategoryId" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                </td>
            </tr>
        }
    </tbody>
</table>
