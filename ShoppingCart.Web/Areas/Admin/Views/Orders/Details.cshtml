@model Order
@{
    ViewData["Title"] = "Поръчка #" + Model.OrderId;
}

<h4>Поръчка #@Model.OrderId</h4>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <p><strong>Дата:</strong> @Model.OrderDate.ToString("dd.MM.yyyy HH:mm")</p>
                <p><strong>Потребител:</strong> @Model.UserId</p>
                <p><strong>Адрес:</strong> @Model.ShippingAddress</p>
                <p><strong>Статус:</strong>
                    <span class="badge @(Model.Status == "Ordered" ? "bg-warning" : "bg-success")">@Model.Status</span>
                </p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h5>Промяна на статус</h5>
                <form asp-action="ChangeStatus" method="post" class="d-flex gap-2">
                    <input type="hidden" name="orderId" value="@Model.OrderId" />
                    <select name="status" class="form-select">
                        <option value="Ordered">Ordered</option>
                        <option value="Shipped">Shipped</option>
                        <option value="Delivered">Delivered</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                    <button type="submit" class="btn btn-dark">Промени</button>
                </form>
            </div>
        </div>
    </div>
</div>

<h5>Артикули</h5>
<table class="table">
    <thead>
        <tr>
            <th>Продукт</th>
            <th>Цена</th>
            <th>Количество</th>
            <th>Общо</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.OrderItems)
        {
            <tr>
                <td>@(item.Product?.Name ?? "Неизвестен")</td>
                <td>@item.UnitPrice.ToString("F2") лв.</td>
                <td>@item.Quantity</td>
                <td>@((item.Quantity * item.UnitPrice).ToString("F2")) лв.</td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr class="fw-bold">
            <td colspan="3" class="text-end">Общо:</td>
            <td>@Model.TotalPrice.ToString("F2") лв.</td>
        </tr>
    </tfoot>
</table>

<a asp-action="Index" class="btn btn-outline-dark"><i class="bi bi-arrow-left"></i> Обратно</a>
