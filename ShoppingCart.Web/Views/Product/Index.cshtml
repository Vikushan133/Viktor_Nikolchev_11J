@model IEnumerable<Product>
@{
    ViewData["Title"] = "Продукти";
}

<div class="container py-4">
    <h1 class="mb-4">Продукти</h1>

    <div class="row">
        @foreach (var product in Model)
        {
            <div class="col-md-3 mb-4">
                <div class="card h-100 border-0 shadow-sm product-card">
                    <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name" style="height: 300px; object-fit: cover;">
                    <span class="badge bg-dark position-absolute top-0 end-0 m-2">@product.Category</span>
                    <div class="card-body d-flex flex-column">
                        <h6 class="card-title">@product.Name</h6>
                        <p class="text-muted small mb-1">@product.Brand</p>
                        <p class="text-muted small">@product.Color | @product.Size</p>
                        <div class="mt-auto">
                            <p class="fw-bold fs-5 mb-2">@product.Price.ToString("F2") лв.</p>
                            @if (User.Identity.IsAuthenticated)
                            {
                                <a asp-controller="Cart" asp-action="AddItem" asp-route-productId="@product.ProductId" class="btn btn-dark btn-sm w-100">
                                    <i class="bi bi-cart-plus"></i> Добави в количка
                                </a>
                            }
                            <a asp-action="Details" asp-route-id="@product.ProductId" class="btn btn-outline-secondary btn-sm w-100 mt-1">Детайли</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .product-card:hover { transform: translateY(-5px); transition: 0.3s; box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important; }
</style>
