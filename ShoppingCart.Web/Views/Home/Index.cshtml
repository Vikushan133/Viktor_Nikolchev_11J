@model List<ShoppingCart.Models.Product>

@{
    ViewData["Title"] = "Начало";
}

<div class="text-center mb-5">
    <h1 class="display-4">Онлайн магазин</h1>
    <p class="lead">Добре дошли в нашия онлайн магазин с пазарска количка.</p>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card text-white bg-primary mb-3">
            <div class="card-body text-center">
                <h5 class="card-title">Продукти</h5>
                <p class="display-6">@ViewBag.TotalProducts</p>
                <a asp-controller="Product" asp-action="Index" class="text-white">Разгледай</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-success mb-3">
            <div class="card-body text-center">
                <h5 class="card-title">Активни колички</h5>
                <p class="display-6">@ViewBag.ActiveCarts</p>
                <a asp-controller="Cart" asp-action="Index" class="text-white">Виж всички</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-info mb-3">
            <div class="card-body text-center">
                <h5 class="card-title">Общо колички</h5>
                <p class="display-6">@ViewBag.TotalCarts</p>
                <a asp-controller="Cart" asp-action="Index" class="text-white">Детайли</a>
            </div>
        </div>
    </div>
</div>

@if (Model.Any())
{
    <h3>Някои от нашите продукти</h3>
    <div class="row">
        @foreach (var product in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">@product.Name</h5>
                        <p class="card-text">@product.Description</p>
                        <p class="card-text"><strong>@product.Price.ToString("F2") лв.</strong></p>
                        <span class="badge bg-secondary">@product.Category</span>
                    </div>
                </div>
            </div>
        }
    </div>
    <div class="text-center">
        <a asp-controller="Product" asp-action="Index" class="btn btn-primary">Виж всички продукти</a>
    </div>
}
