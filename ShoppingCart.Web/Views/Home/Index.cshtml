@model List<Product>
@{
    ViewData["Title"] = "Начало";
}

<!-- Hero Banner -->
<div class="bg-dark text-white py-5 mb-4">
    <div class="container text-center">
        <h1 class="display-4 fw-bold">Fashion Store</h1>
        <p class="lead">Открий най-новите тенденции в модата</p>
        <a asp-controller="Product" asp-action="Index" class="btn btn-light btn-lg mt-3">Разгледай продуктите</a>
    </div>
</div>

<!-- Categories -->
@if (ViewBag.Categories != null)
{
    var categories = ViewBag.Categories as List<Product>;
    <div class="container mb-5">
        <h2 class="mb-4">Категории</h2>
        <div class="row g-3">
            @foreach (var cat in categories.Select(p => p.Category).Distinct().Take(4))
            {
                var catId = categories.First(p => p.Category == cat).CategoryId;
                var img = categories.First(p => p.Category == cat).ImageUrl;
                <div class="col-md-3">
                    <a asp-controller="Product" asp-action="Index" asp-route-categoryId="@catId" class="text-decoration-none">
                        <div class="card border-0 shadow-sm category-card">
                            <img src="@img" class="card-img-top" alt="@cat" style="height: 200px; object-fit: cover;">
                            <div class="card-body text-center">
                                <h5 class="card-title text-dark">@cat</h5>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    </div>
}

<!-- Featured Products -->
<div class="container mb-5">
    <h2 class="mb-4">Популярни продукти</h2>
    <div class="row g-4">
        @foreach (var product in Model)
        {
            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm product-card">
                    <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name" style="height: 300px; object-fit: cover;">
                    <div class="card-body d-flex flex-column">
                        <h6 class="card-title">@product.Name</h6>
                        <p class="text-muted small mb-1">@product.Brand</p>
                        <div class="mt-auto">
                            <p class="fw-bold mb-2">@product.Price.ToString("F2") лв.</p>
                            @if (User.Identity.IsAuthenticated)
                            {
                                <a asp-controller="Cart" asp-action="AddItem" asp-route-productId="@product.ProductId" class="btn btn-dark btn-sm w-100">
                                    <i class="bi bi-cart-plus"></i> Добави
                                </a>
                            }
                            <a asp-controller="Product" asp-action="Details" asp-route-id="@product.ProductId" class="btn btn-outline-secondary btn-sm w-100 mt-1">Детайли</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Newsletter / CTA -->
<div class="bg-light py-5">
    <div class="container text-center">
        <h3>Готов ли си да обновиш гардероба си?</h3>
        <p class="text-muted">Разгледай нашите колекции и избери своите любими парчета.</p>
        <a asp-controller="Product" asp-action="Index" class="btn btn-dark btn-lg">Виж всички продукти</a>
    </div>
</div>

<style>
    .category-card:hover { transform: translateY(-5px); transition: 0.3s; }
    .product-card:hover { transform: translateY(-5px); transition: 0.3s; box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important; }
</style>
