<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Fashion Store</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-shop"></i> Fashion Store
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-grid"></i> Категории
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Product" asp-action="Index">Всички продукти</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-controller="Product" asp-action="Index" asp-route-categoryId="1">T-Shirts</a></li>
                                <li><a class="dropdown-item" asp-controller="Product" asp-action="Index" asp-route-categoryId="2">Jeans</a></li>
                                <li><a class="dropdown-item" asp-controller="Product" asp-action="Index" asp-route-categoryId="3">Sneakers</a></li>
                                <li><a class="dropdown-item" asp-controller="Product" asp-action="Index" asp-route-categoryId="4">Jackets</a></li>
                                <li><a class="dropdown-item" asp-controller="Product" asp-action="Index" asp-route-categoryId="5">Shorts</a></li>
                                <li><a class="dropdown-item" asp-controller="Product" asp-action="Index" asp-route-categoryId="6">Dresses & Skirts</a></li>
                                <li><a class="dropdown-item" asp-controller="Product" asp-action="Index" asp-route-categoryId="7">Accessories</a></li>
                                <li><a class="dropdown-item" asp-controller="Product" asp-action="Index" asp-route-categoryId="8">Sweaters & Hoodies</a></li>
                            </ul>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Cart" asp-action="Index">
                                    <i class="bi bi-cart"></i> Количка
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Order" asp-action="Index">
                                    <i class="bi bi-box"></i> Поръчки
                                </a>
                            </li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                                        <i class="bi bi-gear"></i> Админ
                                    </a>
                                </li>
                            }
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-person"></i> @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right"></i> Изход</a></li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login"><i class="bi bi-box-arrow-in-right"></i> Вход</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Register"><i class="bi bi-person-plus"></i> Регистрация</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="bg-dark text-white py-4 mt-5">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h5><i class="bi bi-shop"></i> Fashion Store</h5>
                    <p class="text-muted">Вашият онлайн магазин за модни дрехи и аксесоари.</p>
                </div>
                <div class="col-md-3">
                    <h6>Бързи връзки</h6>
                    <ul class="list-unstyled">
                        <li><a asp-controller="Product" asp-action="Index" class="text-muted text-decoration-none">Продукти</a></li>
                        <li><a asp-controller="Home" asp-action="Index" class="text-muted text-decoration-none">Начало</a></li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <h6>Контакт</h6>
                    <p class="text-muted">info@fashionstore.bg</p>
                </div>
            </div>
            <hr class="border-secondary">
            <p class="text-center text-muted mb-0">&copy; 2026 Viktor_Nikolchev_11J - Fashion Store. Всички права запазени.</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
