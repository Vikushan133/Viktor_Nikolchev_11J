@model ShoppingCart.Models.Cart

@{
    ViewData["Title"] = "Изтрий количка";
}

<h1>Изтрий количка</h1>

<div class="alert alert-danger">
    <h4>Сигурни ли сте, че искате да изтриете количка #@Model.CartId?</h4>
</div>

<div>
    <dl class="row">
        <dt class="col-sm-2">Клиент</dt>
        <dd class="col-sm-10">@Model.CustomerName</dd>
        <dt class="col-sm-2">Обща цена</dt>
        <dd class="col-sm-10">@Model.TotalPrice.ToString("F2") лв.</dd>
        <dt class="col-sm-2">Статус</dt>
        <dd class="col-sm-10">@Model.Status</dd>
    </dl>
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="CartId" />
    <button type="submit" class="btn btn-danger">Изтрий</button>
    <a asp-action="Index" class="btn btn-secondary">Отказ</a>
</form>
