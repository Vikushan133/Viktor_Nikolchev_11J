@model IEnumerable<Order>
@{
    ViewData["Title"] = "Моите поръчки";
}

<div class="container py-4">
    <h1 class="mb-4"><i class="bi bi-box"></i> Моите поръчки</h1>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox" style="font-size: 4rem;"></i>
            <h3 class="mt-3">Нямате направени поръчки</h3>
            <a asp-controller="Product" asp-action="Index" class="btn btn-dark">Започнете да пазарувате</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th># Поръчка</th>
                        <th>Дата</th>
                        <th>Общо</th>
                        <th>Статус</th>
                        <th>Адрес</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td>#@order.OrderId</td>
                            <td>@order.OrderDate.ToString("dd.MM.yyyy")</td>
                            <td>@order.TotalPrice.ToString("F2") лв.</td>
                            <td>
                                <span class="badge @(order.Status == "Ordered" ? "bg-warning" : "bg-success")">@order.Status</span>
                            </td>
                            <td>@order.ShippingAddress</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@order.OrderId" class="btn btn-sm btn-outline-dark">Детайли</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
